{
  "contract_version": 1,
  "id": "lrspike",
  "title": "LR Spike Experiment",
  "paper_result": "LR-spike controller comparison",
  "dataset": "sklearn digits",
  "entry_point": "run.py",
  "smoke_test": {
    "kind": "help",
    "args": [
      "--help"
    ]
  },
  "smoke_run": {
    "kind": "command",
    "command": [
      "python",
      "run.py",
      "--seeds",
      "0",
      "--lrs",
      "1e-3",
      "--steps",
      "6",
      "--spike-at",
      "3",
      "--spike-mul",
      "10.0",
      "--device",
      "cpu",
      "--print-every",
      "0",
      "--tag",
      "smoke"
    ],
    "expected_artifacts": [
      "cache/lrsweep_multiseed_smoke.pt",
      "experiments/lrspike/results/lrsweep-jvp-multiseed_smoke.png",
      "experiments/lrspike/results/lrsweep-jvp-multiseed_smoke.pdf",
      "experiments/lrspike/results/summary_smoke.json"
    ]
  },
  "canonical_command": [
    "python",
    "run.py",
    "--seeds",
    "0,1,2,3,4",
    "--lrs",
    "1e-4,1e-3,1e-2",
    "--steps",
    "200",
    "--spike-at",
    "50",
    "--spike-mul",
    "1000.0",
    "--device",
    "auto"
  ],
  "artifacts": [
    "cache/lrsweep_multiseed.pt",
    "experiments/lrspike/results/lrsweep-jvp-multiseed.png",
    "experiments/lrspike/results/lrsweep-jvp-multiseed.pdf",
    "experiments/lrspike/results/summary.json"
  ],
  "notes": "Cache output lands alongside the experiment."
}
