{
  "contract_version": 1,
  "id": "tempfingerprint",
  "title": "Temperature Fingerprint Experiment",
  "paper_result": "Temperature-scaling fingerprint",
  "dataset": "sklearn digits",
  "entry_point": "run.py",
  "smoke_test": {
    "kind": "help",
    "args": [
      "--help"
    ]
  },
  "smoke_run": {
    "kind": "command",
    "command": [
      "python",
      "run.py",
      "--seeds",
      "0",
      "--temps",
      "1,2",
      "--train-steps",
      "8",
      "--train-lr",
      "0.01",
      "--batch-size",
      "64",
      "--device",
      "cpu",
      "--tag",
      "smoke"
    ],
    "expected_artifacts": [
      "cache/fingerprint_multiseed_smoke.pt",
      "experiments/tempfingerprint/results/theory-fingerprint-tests_v4_smoke.png",
      "experiments/tempfingerprint/results/theory-fingerprint-tests_v4_smoke.pdf",
      "experiments/tempfingerprint/results/summary_smoke.json"
    ]
  },
  "canonical_command": [
    "python",
    "run.py",
    "--seeds",
    "0,1,2,3,4",
    "--temps",
    "0.25,0.5,1,2,4,8",
    "--train-steps",
    "120",
    "--train-lr",
    "0.01",
    "--batch-size",
    "256",
    "--device",
    "auto"
  ],
  "artifacts": [
    "cache/fingerprint_multiseed.pt",
    "experiments/tempfingerprint/results/theory-fingerprint-tests_v4.png",
    "experiments/tempfingerprint/results/theory-fingerprint-tests_v4.pdf",
    "experiments/tempfingerprint/results/summary.json"
  ],
  "notes": "Cache output lands alongside the experiment."
}
