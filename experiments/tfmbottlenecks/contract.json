{
  "contract_version": 1,
  "id": "tfmbottlenecks",
  "title": "Transformer Bottlenecks Experiment",
  "paper_result": "Tiny-transformer bottleneck comparison",
  "dataset": "sklearn digits",
  "entry_point": "run.py",
  "smoke_test": {
    "kind": "help",
    "args": [
      "--help"
    ]
  },
  "smoke_run": {
    "kind": "command",
    "command": [
      "python",
      "run.py",
      "--seeds",
      "0",
      "--modes",
      "all-radii,output-only",
      "--steps",
      "40",
      "--eval-every",
      "10",
      "--lr-base",
      "0.002",
      "--device",
      "cpu",
      "--tag",
      "smoke"
    ],
    "expected_artifacts": [
      "experiments/tfmbottlenecks/cache/transformer_radii_multiseed_smoke.pt",
      "experiments/tfmbottlenecks/results/transformer-radii-compare_smoke.png",
      "experiments/tfmbottlenecks/results/transformer-radii-compare_smoke.pdf",
      "experiments/tfmbottlenecks/results/summary_smoke.json"
    ]
  },
  "canonical_command": [
    "python",
    "run.py",
    "--seeds",
    "0,1,2,3,4",
    "--modes",
    "all-radii,output-only,fixed-1x,fixed-16x",
    "--steps",
    "1200",
    "--eval-every",
    "20",
    "--lr-base",
    "2e-3",
    "--device",
    "auto"
  ],
  "artifacts": [
    "experiments/tfmbottlenecks/cache/transformer_radii_multiseed.pt",
    "experiments/tfmbottlenecks/results/transformer-radii-compare.png",
    "experiments/tfmbottlenecks/results/transformer-radii-compare.pdf",
    "experiments/tfmbottlenecks/results/summary.json"
  ],
  "notes": "Cache output lands alongside the experiment. The all-radii mode uses the FFN proxy rho_ffn = Q0.01(|h|/|dh|)."
}
