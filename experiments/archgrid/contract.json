    "--base-lr",
    "0.015",
    "--spike-at",
    "50",
    "--spike-mul",
    "10.0",
    "--device",
    "auto"
  ],
  "artifacts": [
    "experiments/falsify/data/archgrid_multiseed.pt",
    "experiments/archgrid/results/archgrid-jvp-twocol.png",
    "experiments/archgrid/results/archgrid-jvp-twocol.pdf",
    "experiments/archgrid/results/summary.json"
  ],
  "notes": "Historical cache output currently lands under experiments/falsify/data."
}
