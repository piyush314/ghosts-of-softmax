{
  "contract_version": 1,
  "id": "archgrid",
  "title": "Architecture Grid Experiment",
  "paper_result": "Cross-architecture spike comparison",
  "dataset": "sklearn digits",
  "entry_point": "run.py",
  "smoke_test": {
    "kind": "help",
    "args": [
      "--help"
    ]
  },
  "smoke_run": {
    "kind": "command",
    "command": [
      "python",
      "run.py",
      "--seeds",
      "0",
      "--archs",
      "MLP+LN",
      "--steps",
      "4",
      "--base-lr",
      "0.01",
      "--spike-at",
      "2",
      "--spike-mul",
      "2.0",
      "--device",
      "cpu",
      "--tag",
      "smoke"
    ],
    "expected_artifacts": [
      "experiments/archgrid/cache/archgrid_multiseed_smoke.pt",
      "experiments/archgrid/results/archgrid-jvp-twocol_smoke.png",
      "experiments/archgrid/results/archgrid-jvp-twocol_smoke.pdf",
      "experiments/archgrid/results/summary_smoke.json"
    ]
  },
  "canonical_command": [
    "python",
    "run.py",
    "--seeds",
    "0,1,2,3,4",
    "--archs",
    "Transformer,MLP+LN,CNN+BN",
    "--steps",
    "200",
    "--base-lr",
    "0.015",
    "--spike-at",
    "50",
    "--spike-mul",
    "10.0",
    "--device",
    "auto"
  ],
  "artifacts": [
    "experiments/archgrid/cache/archgrid_multiseed.pt",
    "experiments/archgrid/results/archgrid-jvp-twocol.png",
    "experiments/archgrid/results/archgrid-jvp-twocol.pdf",
    "experiments/archgrid/results/summary.json"
  ],
  "notes": "Cache output lands alongside the experiment."
}
